# Dark kiosk theme base.

<Screen>:
    canvas.before:
        Color:
            rgba: 0.04, 0.07, 0.12, 1
        Rectangle:
            size: self.size
            pos: self.pos

<Button>:
    background_normal: ""
    background_color: 0.1, 0.8, 0.9, 1
    color: 0.02, 0.05, 0.09, 1
    font_bold: True

<Label>:
    color: 0.95, 0.99, 1, 1

<TextInput>:
    multiline: False
    font_size: "18sp"
    background_color: 0.08, 0.12, 0.18, 1
    foreground_color: 0.95, 0.99, 1, 1
